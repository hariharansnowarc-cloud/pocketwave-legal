<!-- MOCK FEED -->
<section class="feed-section" id="feed">
  <div class="feed-inner">
    <p class="section-label" style="text-align:center;margin-bottom:0.5rem">Live preview</p>
    <h2 class="section-title" style="text-align:center;margin-bottom:2rem;font-size:clamp(1.5rem,3vw,2rem)">What it looks like inside</h2>

    <div class="feed-header">
      <div class="feed-city">
